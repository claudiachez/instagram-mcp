# Instagram Business/Creator account ID (numeric, NOT the @username)
# Get via: GET /me/accounts then GET /{page-id}?fields=instagram_business_account
IG_USER_ID=

# Long-lived Page access token with the scopes you need:
#   instagram_basic, instagram_content_publish, instagram_manage_comments,
#   instagram_manage_messages, instagram_manage_insights, pages_show_list,
#   pages_read_engagement, business_management
IG_ACCESS_TOKEN=

# Graph API version (override if you need a different one)
IG_GRAPH_VERSION=v21.0

# API host. Use graph.instagram.com if you got the token via "API setup with
# Instagram login". Use graph.facebook.com if you used "API setup with Facebook
# login" or a Page token from Graph API Explorer.
IG_GRAPH_HOST=graph.facebook.com
